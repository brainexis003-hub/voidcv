# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=
GEMINI_API_KEY_1=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
GEMINI_API_KEY_4=

# CEREBRAS_API_KEY_PRIMARY: Required for Cerebras AI API calls (Priority 1).
# Users configure this via the Secrets panel in the AI Studio UI.
CEREBRAS_API_KEY_PRIMARY=

# CEREBRAS_API_KEY_SECONDARY: Required for GLM (on Cerebras) API calls (Priority 4).
# Users configure this via the Secrets panel in the AI Studio UI.
CEREBRAS_API_KEY_SECONDARY=

# CEREBRAS_API_KEY: Required for Cerebras AI API calls.
# Users configure this via the Secrets panel in the AI Studio UI.
CEREBRAS_API_KEY=

# NVIDIA_API_KEY: Required for NVIDIA/MiniMax-M3 AI API calls.
# Users configure this via the Secrets panel in the AI Studio UI.
NVIDIA_API_KEY=

# GROQ_API_KEY: Required for Groq AI API calls.
# Users configure this via the Secrets panel in the AI Studio UI.
GROQ_API_KEY=

# GLM_API_KEY: Required for GLM (on Cerebras) API calls.
# Users configure this via the Secrets panel in the AI Studio UI.
GLM_API_KEY=

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL=
